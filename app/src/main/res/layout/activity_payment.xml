<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Payment Method Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#C8E6C9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Method"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <!-- VISA -->
                    <TextView
                        android:id="@+id/btnVisa"
                        android:layout_width="70dp"
                        android:layout_height="45dp"
                        android:text="VISA"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="#1A1F71"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                    <!-- MASTERCARD -->
                    <TextView
                        android:id="@+id/btnMaster"
                        android:layout_width="70dp"
                        android:layout_height="45dp"
                        android:text="MC"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="#EB001B"
                        android:alpha="0.4"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                    <!-- BANK -->
                    <TextView
                        android:id="@+id/btnBank"
                        android:layout_width="70dp"
                        android:layout_height="45dp"
                        android:text="BANK"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="#0055A5"
                        android:alpha="0.4"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Total Amount -->
        <TextView
            android:id="@+id/txtTotalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOTAL AMOUNT - $200"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Card Payment Section -->
        <LinearLayout
            android:id="@+id/cardSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card Payment"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/imgSelectedCard"
                android:layout_width="70dp"
                android:layout_height="45dp"
                android:src="@drawable/ic_visa"
                android:scaleType="fitCenter"
                android:layout_marginBottom="16dp"
                android:contentDescription="Selected card"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_grey"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name on card"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etCardName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@null"
                android:textSize="14sp"
                android:autofillHints="name"
                android:layout_marginBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_grey"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card Number"
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etCardNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@null"
                android:inputType="number"
                android:textSize="14sp"
                android:autofillHints="creditCardNumber"
                android:layout_marginBottom="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/text_grey"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expiry"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MM/YY"
                        android:textSize="12sp"
                        android:textColor="@color/text_grey"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:hint="MM/YY"
                        android:focusable="false"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:textSize="14sp"
                        android:autofillHints="creditCardExpirationDate"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/text_grey"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CVC"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etCvc"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:inputType="number"
                        android:textSize="14sp"
                        android:autofillHints="creditCardSecurityCode"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/text_grey"/>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="Submit"
            android:textAllCaps="false"
            android:textColor="@color/text_dark"
            android:backgroundTint="#DDDDDD"/>

    </LinearLayout>
</ScrollView>