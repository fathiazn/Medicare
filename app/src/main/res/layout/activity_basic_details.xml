<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Step Indicator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Basic Details"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tell us about yourself"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="28dp"/>

        <!-- Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Full Name" android:textColor="#374151" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:hint="Enter your full name"
            android:paddingStart="16dp"
            android:inputType="textPersonName"
            android:layout_marginBottom="16dp"/>

        <!-- Age -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Age" android:textColor="#374151" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etAge"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:hint="Enter your age"
            android:paddingStart="16dp"
            android:inputType="number"
            android:layout_marginBottom="16dp"/>

        <!-- Gender -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Gender" android:textColor="#374151" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinnerGender"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:entries="@array/gender_options"
            android:layout_marginBottom="16dp"/>

        <!-- Height -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Height (cm)" android:textColor="#374151" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etHeight"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:hint="e.g. 170"
            android:paddingStart="16dp"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp"/>

        <!-- Weight -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Weight (kg)" android:textColor="#374151" android:textSize="13sp"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etWeight"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:hint="e.g. 65"
            android:paddingStart="16dp"
            android:inputType="numberDecimal"
            android:layout_marginBottom="32dp"/>

        <!-- Next Button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Next →"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:radius="12dp"/>

    </LinearLayout>
</ScrollView>