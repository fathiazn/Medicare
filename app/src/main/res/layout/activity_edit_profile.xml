<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F8FF">

    <!-- SCROLLABLE FORM -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Profile"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#0D1B2A"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update your information"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="24dp"/>

            <!-- BASIC INFO -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Basic Information" android:textSize="15sp" android:textStyle="bold"
                android:textColor="#1565C0" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Full Name" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etName" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:inputType="textPersonName"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Age" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etAge" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:inputType="number"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gender" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerGender" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:entries="@array/gender_options"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Height (cm)" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etHeight" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:inputType="numberDecimal"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Weight (kg)" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etWeight" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:inputType="numberDecimal"
                android:layout_marginBottom="24dp"/>

            <!-- MEDICAL INFO -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Medical Information" android:textSize="15sp" android:textStyle="bold"
                android:textColor="#1565C0" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Blood Group" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerBloodGroup" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:entries="@array/blood_group_options"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Blood Pressure (mmHg)" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etBloodPressure" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:hint="e.g. 120/80" android:paddingStart="16dp" android:inputType="text"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Heart Rate (bpm)" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etHeartRate" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:hint="e.g. 72" android:paddingStart="16dp" android:inputType="number"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Known Conditions" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etConditions" android:layout_width="match_parent"
                android:layout_height="80dp" android:background="@drawable/input_bg"
                android:hint="e.g. Diabetes" android:paddingStart="16dp" android:paddingTop="12dp"
                android:inputType="textMultiLine" android:gravity="top"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Allergies" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etAllergies" android:layout_width="match_parent"
                android:layout_height="80dp" android:background="@drawable/input_bg"
                android:hint="e.g. Penicillin" android:paddingStart="16dp" android:paddingTop="12dp"
                android:inputType="textMultiLine" android:gravity="top"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Current Medications" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etMedications" android:layout_width="match_parent"
                android:layout_height="80dp" android:background="@drawable/input_bg"
                android:hint="e.g. Metformin 500mg" android:paddingStart="16dp" android:paddingTop="12dp"
                android:inputType="textMultiLine" android:gravity="top"
                android:layout_marginBottom="24dp"/>

            <!-- LIFESTYLE -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lifestyle" android:textSize="15sp" android:textStyle="bold"
                android:textColor="#1565C0" android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Activity Level" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerActivity" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:entries="@array/activity_options"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Smoking" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerSmoking" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:entries="@array/smoking_options"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Alcohol" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerAlcohol" android:layout_width="match_parent"
                android:layout_height="52dp" android:background="@drawable/input_bg"
                android:paddingStart="16dp" android:entries="@array/alcohol_options"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Diet" android:textColor="#374151" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etDiet" android:layout_width="match_parent"
                android:layout_height="80dp" android:background="@drawable/input_bg"
                android:hint="e.g. Vegetarian" android:paddingStart="16dp" android:paddingTop="12dp"
                android:inputType="textMultiLine" android:gravity="top"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- STICKY BUTTONS AT BOTTOM (always visible) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="← Back"
            android:textColor="#1565C0"
            android:backgroundTint="#E8F0FE"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Save Changes"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</LinearLayout>